@njit
def f(v,ik):
    out   = np.zeros(v.shape, dtype=np.float64)
    dm    = np.zeros((no,no), dtype=np.complex128)
    Hermconstr(dm,   v[0:nsigr], v[nsigr:ns])
    if np.abs(dm - dm.conj().T).sum()> 1e-13:
        print('DM not Hermitian!!!!!!')
        print(np.where(np.abs(dm - dm.conj().T)>1e-13))
    
    vpsiR =  v[ ns       : (ns+npsi)  ].reshape(na, nx, noT, no)
    vpsiI =  v[(ns+npsi) : (ns+2*npsi)].reshape(na, nx, noT, no)
    vomgR =  v[(ns+2*npsi):(ns+2*npsi + nomg)]          .reshape(na,nx,noT,na,nx,noT)
    vomgI =  v[(ns+2*npsi + nomg): (ns+2*npsi + 2*nomg)].reshape(na,nx,noT,na,nx,noT)
    omg   =  vomgR + 1j*vomgI
    psi   =  vpsiR + 1j*vpsiI
    psic  =  np.conj(psi)
    Hk    =  H0 [ik] 
    X     =  xi [ik]
    IX    =  Ixi[ik]
    IXc   =  IXC[ik]
    
    ODM   =  np.zeros((no,no),dtype=np.complex128)
    for a in range(na): 
        for x in range(nx): 
            for c in range(noT):
                outer_add(psi[a,x,c],  IX[a,x,c],  ODM)
                outer_add(IXc[a,x,c],psic[a,x,c],  ODM)
    
    ODM *= 1j/hbar
    ODM += np.dot(Hk, dm) - np.dot(dm, Hk)
    OPSI = np.zeros((na,nx,noT, no), dtype=np.complex128)
    OOMG = np.zeros((na,nx,noT,na,nx,noT), dtype=np.complex128)
    
    SUM            = np.zeros(no,dtype=np.complex128)
    OMGaxc         = np.zeros((na,nx,noT),dtype=np.complex128)
    
    for a in range(na):
        for x in range(nx):
            for c in range(noT):
                DMxi  = np.dot(dm, X[a,x,c])
                OPSI[a,x,c,:] += hbar*diff_GGP_GLP[ik,a,x,c]*DMxi
                SUM[:]        = 0.0
                Baxc           = omg[a,x,c,:,:,:]
                for a2 in range(na):
                    for x2 in range(nx):
                        for c2 in range(noT):
                            SUM += omg[a,x,c,a2,x2,c2] * X[a2,x2,c2]
                            OMGaxc[a2,x2,c2]  = (Xpm[ik,a2,x2,c2] - Xpp[ik,a , x, c]) * Baxc[a2,x2,c2]
                            OMGaxc[a2,x2,c2] +=  (1j*hbar)*diff_GGM_GLM[ik,a2,x2,c2]\
                                                 *np.dot(IX [a2,x2,c2],psi[a,x,c])
                            OMGaxc[a2,x2,c2] +=  (1j*hbar)*diff_GGP_GLP[ik,a, x, c]     \
                                                 *np.dot(psic[a2,x2,c2], X[a,x,c])
                
                OOMG[a,x,c  ] =   OMGaxc[:,:,:]
                OPSI[a,x,c,:] +=  SUM
                OPSI[a,x,c,:] +=  np.dot(ig_kaxc[ik,a,x,c], psi[a,x,c,:])
                OPSI[a,x,c,:] +=  hbar*GLP[ik,a,x,c] * X[a,x,c]
    
    
    Hermravel(ODM, out[0:nsigr], out[nsigr:(nsigr + nsigi)])
    out[ns        : (ns +  npsi)] = OPSI.reshape(na*nx*noT*no).real
    out[(ns+npsi) : (ns +2*npsi)] = OPSI.reshape(na*nx*noT*no).imag
    
    out[(ns+2*npsi):(ns+2*npsi + nomg)]           = OOMG.reshape(na*nx*noT*na*nx*noT).real
    out[(ns+2*npsi + nomg): (ns+2*npsi + 2*nomg)] = OOMG.reshape(na*nx*noT*na*nx*noT).imag
    return out

