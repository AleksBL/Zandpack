@njit
def Hermravel(M,vecr, veci):
    no = M.shape[0]
    assert len(vecr) == (no*(no+1))//2
    assert len(veci) == (no*(no+1))//2 - no
    itr, iti = 0,0
    for i in range(no):
        for j in range(i,no):
            vecr[itr] = M[i,j].real
            itr += 1
            if j>i:
                veci[iti] = M[i,j].imag
                iti += 1
    
    assert itr == len(vecr)
    assert iti == len(veci)

@njit
def Hermconstr(M,vecr,veci):
    no = M.shape[0]
    assert len(vecr) == (no*(no+1))//2
    assert len(veci) == (no*(no+1))//2 - no
    itr,iti = 0,0
    for i in range(no):
        for j in range(i,no):
            M[i,j]  = vecr[itr]
            M[j,i]  = vecr[itr]
            itr    += 1
            if j>i:
                v       = 1j*veci[iti]
                M[i,j] += v
                M[j,i] -= v
                iti    += 1
    assert itr == len(vecr)
    assert iti == len(veci)

@njit
def outer_add(a,b,out):
    NA,NB = len(a),len(b)
    for i in range(NA):
        for j in range(NB):
            out [i,j] += (a[i]*b[j])
@njit
def Av2(v, ik):
    out   = np.zeros(v.shape, dtype=np.float64)
    dm    = np.zeros((no,no), dtype=np.complex128)
    Hermconstr(dm,   v[0:nsigr], v[nsigr:ns])
    
    if np.abs(dm - dm.conj().T).sum()> 1e-13:
        print('DM not Hermitian!!!!!!')
        print(np.where(np.abs(dm - dm.conj().T)>1e-13))
    
    vpsiR =  v[ ns       : (ns+npsi)  ].reshape(na, nx, noT, no)
    vpsiI =  v[(ns+npsi) : (ns+2*npsi)].reshape(na, nx, noT, no)
    psi   =  vpsiR + 1j*vpsiI
    psic  =  np.conj(psi)
    Hk    =  H0 [ik] 
    X     =  xi [ik]
    IX    =  Ixi[ik]
    IXc   =  IXC[ik]
    ODM   =  np.zeros((no,no),dtype=np.complex128)
    
    for a in range(na): 
        for x in range(nx): 
            for c in range(noT):
                outer_add(psi[a,x,c],  IX[a,x,c],  ODM)
                outer_add(IXc[a,x,c],psic[a,x,c],  ODM)
    
    ODM *= 1j/hbar
    ODM += np.dot(Hk, dm) - np.dot(dm, Hk)
    OPSI = np.zeros((na,nx,noT, no), dtype=np.complex128)
    SUM            = np.zeros(no,dtype=np.complex128)
    
    for a in range(na):
        for x in range(nx):
            for c in range(noT):
                DMxi  = np.dot(dm, X[a,x,c])
                OPSI[a,x,c,:] += hbar*diff_GGP_GLP[ik,a,x,c]*DMxi
                SUM[:] = 0.0
                for a2 in range(na):
                    for x2 in range(nx):
                        for o2 in range(noT):
                            frac = 1j/(Xpm[ik, a2, x2, o2] 
                                     - Xpp[ik, a, x, c])
                            SUM += (diff_GGM_GLM[ik, a2,x2,o2]\
                                    *np.dot(IX [a2,x2,o2],
                                            psi[a,x,c])
                                    *frac)*X[a2, x2, o2]
                            SUM += (diff_GGP_GLP[ik,a,x,c]\
                                    *np.dot(psic[a2,x2,o2],
                                            X[a,x,c])
                                    *frac)*X[a2, x2, o2]
                OPSI[a,x,c]   -= SUM
                OPSI[a,x,c,:] +=  np.dot(ig_kaxc[ik,a,x,c], psi[a,x,c,:])
    
    Hermravel(ODM, out[0:nsigr], out[nsigr:(nsigr + nsigi)])
    out[ns        : (ns +  npsi)] = OPSI.reshape(na*nx*noT*no).real
    out[(ns+npsi) : (ns +2*npsi)] = OPSI.reshape(na*nx*noT*no).imag
    
    return out

