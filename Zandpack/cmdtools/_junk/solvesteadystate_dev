@njit(fastmath=True, parallel=True)
def Av3(v, ik):
    out   = np.zeros(v.shape, dtype=np.float64)
    
    vpsiR =  v[ 0  :   npsi].reshape(na, nx, noT, no)
    vpsiI =  v[npsi: 2*npsi].reshape(na, nx, noT, no)
    psi   =  vpsiR + 1j*vpsiI
    psic  =  np.conj(psi)
    Hk    =  H0 [ik] 
    X     =  xi [ik]
    IX    =  Ixi[ik]
    IXc   =  IXC[ik]
    
    OPSI = np.zeros((na,nx,noT, no), dtype=np.complex128)
    
    for x in prange(nx):
        for a in range(na):
            for c in range(noT):
                SUM            = np.zeros(no,dtype=np.complex128)
                for a2 in range(na):
                    for x2 in range(nx):
                        for o2 in range(noT):
                            frac = 1j/(Xpm[ik, a2, x2, o2] 
                                     - Xpp[ik, a, x, c])
                            SUM += (diff_GGM_GLM[ik, a2,x2,o2]\
                                    *np.dot(IX [a2,x2,o2],
                                            psi[a,x,c])
                                    *frac)*X[a2, x2, o2]
                            SUM += (diff_GGP_GLP[ik,a,x,c]\
                                    *np.dot(psic[a2,x2,o2],
                                            X[a,x,c])
                                    *frac)*X[a2, x2, o2]
                OPSI[a,x,c,:] -= SUM
                OPSI[a,x,c,:] += np.dot(ig_kaxc[ik,a,x,c], psi[a,x,c,:])
    
    out[0    :   npsi] = OPSI.reshape(na*nx*noT*no).real
    out[npsi : 2*npsi] = OPSI.reshape(na*nx*noT*no).imag
    
    return out

def B3(ik,DM):
    b     = np.zeros(2*npsi)
    psi_b = np.zeros((na, nx, noT, no), dtype=np.complex128)
    X     = xi[ik]
    for a in range(na):
        for x in range(nx):
            for c in range(noT):
                psi_b[a,x,c] = + hbar*GLP[ik,a,x,c] *  X[a,x,c] + hbar * diff_GGP_GLP[ik,a,x,c]*DM @ X[a,x,c]
    
    b[0 : npsi ]    = psi_b.reshape(na*nx*noT*no).real
    b[npsi: 2*npsi] = psi_b.reshape(na*nx*noT*no).imag
    
    return b


