def ravel(s):
    return np.hstack([s.ravel().real, s.ravel().imag])

n_ele = np.prod(psi_sh)
def unravel(s):
    a = np.zeros(psi_sh, dtype=np.complex128)
    a[:,:,:,:,:] +=    s[0:n_ele      ].reshape(psi_sh)
    a[:,:,:,:,:] += 1j*s[n_ele:2*n_ele].reshape(psi_sh)
    return a
@njit
def calculate_psi_derivative(psi0,
                             ):
    
    out = np.zeros(psi0.shape, dtype = np.complex128)
    nk,na,nx,noT,no = psi0.shape
    psic = psi0.conj()
    
    for ik in range(nk):
        sigk = DM[ik].copy()
        Hk   = Ham[ik].copy()
        I    = np.eye(Hk.shape[-1])
        for ia1 in range(na):
            for ix1 in range(nx):
                for io1 in range(noT):
                    out[ik, ia1, ix1, io1] += (Hk  - Xpp[ik, ia1, ix1, io1]*I).dot(
                                               psi0[ik, ia1, ix1, io1,:])
                    out[ik, ia1, ix1, io1] += hbar*\
                        GLP[ik, ia1, ix1, io1] * xi[ik, ia1, ix1, io1,:]
                    out[ik, ia1, ix1, io1] += hbar*\
                        diff_GGP_GLP[ik, ia1, ix1, io1] * sigk.dot(xi[ik, ia1, ix1, io1,:])
                    
                    SUM = np.zeros(no, dtype=np.complex128)
                    for ia2 in range(na):
                        for ix2 in range(nx):
                            for io2 in range(no):
                                frac = 1/(Xpm[ik, ia2, ix2, io2] 
                                        - Xpp[ik, ia1, ix1, io1])
                                
                                SUM += (diff_GGM_GLM[ik,ia2,ix2,io2]\
                                        *Ixi [ik,ia2,ix2,io2].dot(
                                         psi0[ik,ia1,ix1,io1]   )
                                        )*frac*xi[ik, ia2, ix2, io2]
                                
                                if io2<noT:
                                    SUM += (diff_GGP_GLP[ik,ia1,ix1,io1]\
                                            *psic[ik,ia2,ix2,io2].dot(
                                                   xi[ik,ia1,ix1,io1]    )
                                            )*frac*xi[ik, ia2, ix2, io2]
                    
                    out[ik,ia1,ix1,io1] -= 1j * SUM
    return out

                    
                    
                    
                    
                    
                    
