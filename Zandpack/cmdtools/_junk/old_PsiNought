@njit
def HCommat():
    M = np.zeros((nk,no**2, no**2), dtype = np.complex128)
    c1 = 0
    for ik in range(nk):
        for i in range(no):
            for ii in range(no):
                c2 = 0
                B1 = np.zeros((no,no),dtype=np.complex128)
                B1[i,ii] = 1
                for j in range(no):
                    for jj in range(no):
                        B2 = np.zeros((no,no), dtype=np.complex128)
                        B2[j,jj] = 1
                        res = Ham[ik].dot(B2) - B2.dot(Ham[ik]) 
                        M[ik, c1,c2] = np.sum(B1 * res)
                        c2 += 1
                c1 += 1
    return M

