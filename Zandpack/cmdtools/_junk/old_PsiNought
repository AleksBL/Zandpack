@njit
def FixPoint(Psi0, DM):
    Psi0conj = Psi0.conj()
    Out      = np.zeros(Psi0.shape, dtype = Psi0.dtype)
    nk,na,nx,noT,no = Psi0.shape
    for ik in range(nk):
        sigk = DM[ik].copy()
        for ia1 in range(na):
            for ix1 in range(nx):
                for io1 in range(noT):
                    vec = np.zeros(no, dtype = np.complex128)
                    vec-=\
                        hbar*GLP[ik,ia1,ix1,io1]*xi[ik,ia1,ix1,io1]
                    
                    vec-=\
                        hbar*diff_GGP_GLP[ik,ia1,ix1,io1]*sigk.dot(xi[ik,ia1,ix1,io1])
                    
                    SUM = np.zeros(no, dtype=np.complex128)
                    for ia2 in range(na):
                        for ix2 in range(nx):
                            for io2 in range(noT):
                                frac = 1/(Xpm[ik, ia2, ix2, io2] 
                                        - Xpp[ik, ia1, ix1, io1])
                    
                                val = (diff_GGM_GLM[ik,ia2,ix2,io2]\
                                        *Ixi [ik,ia2,ix2,io2].dot(
                                         Psi0[ik,ia1,ix1,io1]   )
                                        )*frac#*xi[ik, ia2, ix2, io2]
                                val += (diff_GGP_GLP[ik,ia1,ix1,io1]\
                                        *Psi0conj[ik,ia2,ix2,io2].dot(
                                               xi[ik,ia1,ix1,io1]    )
                                        )*frac#*xi[ik, ia2, ix2, io2]
                                SUM += val * xi[ik,ia1,ix2,io2]
                    vec += 1j *SUM
                    Out[ik,ia1,ix1,io1]  = g_kaxc[ik,ia1,ix1].dot(vec)
    return Out

