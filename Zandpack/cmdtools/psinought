mdot = np.linalg.multi_dot
inv  = np.linalg.inv
sum_psi_vec   = []
sig_absmax_vec= []

for IK in range(nk):
    xi      = XI[IK].copy()
    ixi     = IXI[IK].copy()
    ggp     = GGP[IK].copy()
    ggm     = GGM[IK].copy()
    glp     = GLP[IK].copy()
    glm     = GLM[IK].copy()
    deltaM  = ggm-glm
    _deltaM = deltaM.reshape(compound,1).copy()
    deltaP  = ggp-glp

    xpp = XPP[IK].copy()
    xpm = XPM[IK].copy()
    h0  = H0[IK].copy()
    dm0 = DM0[IK].copy()
    I   = np.eye(no)
    if options['L_info']=='True':
        L0  =  Louivillian(h0)
        L0.calculate_Leigv()
    @njit(fastmath = True)
    def Av3(v, out, OPSI, alloc_psi, psic#, includefrac = 1.0
            ):
        assert out.shape == v.shape
        alloc_psi[:,:,:,:]  =     v[ 0  :   npsi].reshape(na, nx, noT, no)
        alloc_psi[:,:,:,:] +=  1j*v[npsi: 2*npsi].reshape(na, nx, noT, no)
        psic     [:,:,:,:]  =     alloc_psi[:,:,:,:].real
        psic     [:,:,:,:] += -1j*(alloc_psi[:,:,:,:].imag)
        
        X_sum               = xi.reshape(compound,no).T
        
        for a in range(na):
            for x in range(nx):
                ig = I * xpp[a,x,0]-h0
                FRAC =  (1j/(  xpm - xpp[a, x, 0])).reshape(compound,1)
                ARR1 = (FRAC*_deltaM) * ixi.reshape(compound,no)
                ARR2 = FRAC.reshape(compound,1) * psic.reshape(compound,no)
                
                for c in range(noT):
                    
                    SUM  = np.dot(X_sum, np.dot(ARR1, alloc_psi[a,x,c]))
                    SUM += np.dot(X_sum, np.dot(ARR2, deltaP[a,x,c]*xi[a,x,c]))#* includefrac
                    SUM += np.dot(ig, alloc_psi[a,x,c])
                    OPSI[a,x,c,:]  = SUM
                    
        
        out[0    :   npsi] = OPSI.reshape(na*nx*noT*no).real
        out[npsi : 2*npsi] = OPSI.reshape(na*nx*noT*no).imag
        return out
    
    def B3():
        b     = np.zeros(2*npsi)
        psi_b = np.zeros((na, nx, noT, no), dtype=np.complex128)
        for a in range(na):
            for x in range(nx):
                for c in range(noT):
                    psi_b[a,x,c] = hbar*glp[a,x,c]*xi[a,x,c] + hbar * deltaP[a,x,c]* dm0 @ xi[a,x,c]
        
        b[0   :   npsi] = psi_b.reshape(na*nx*noT*no).real
        b[npsi: 2*npsi] = psi_b.reshape(na*nx*noT*no).imag
        return b
        
    def diagmat():
        I  = np.eye(h0.shape[1])
        rms = slice(0,   no)
        ims = slice(no,2*no)
        
        _M       = np.zeros((2*no, 2*no))
        it       = 0
        dtype    = np.float32
        if options['memory_save'] == 'False' and options['outer_einsum']=='False':
            outer    = (xi[:,:,:,:,None]@(xi.conj())[:,:,:,None,:]).reshape(na*nx*noT, no,no).transpose(1,2,0)
        elif options['outer_einsum']=='False':
            outer    = (xi[:,:,:,:,None].astype(np.complex64)@(xi.conj().astype(np.complex64))[:,:,:,None,:]).reshape(na*nx*noT, no,no).transpose(1,2,0)
        else:
            xi_ijk  = xi.reshape(na*nx*noT,no).copy()
            xid_ijk = xi.reshape(na*nx*noT,no).conj()
            outer=None
        
        print('Outer done!')
        vals    = []
        slices1 = []
        slices2 = []
        Xpp_optim = options['Xpp_optim'] =='True'
        W_inv    = options['Woodbury-inv']=='True'
        vu,vv     = np.zeros((2*no,4)),np.zeros((2*no,4))
        #SM_out    = np.zeros((2*no, 2*no))
        for a in range(na):
            print('Electrode ',a)
            for x in tqdm(range(nx)):
                for c in range(noT):
                    if c == 0 or Xpp_optim == False:
                        # if Xpp_optim is False, then this part will execute on all c's
                        # if the Xpp_optim is enabled, only when c = 0, the values are calculated.
                        # because X_axc = X_ax0 right now, this is okay
                        m = -(h0 - I * xpp[a,x,c])
                        o_dtype = outer.dtype if options['outer_einsum']==False else xi_ijk.dtype
                        FRAC     = (1j*deltaM/(xpm -xpp[a,x,c])).astype(o_dtype)
                        Bij      = np.zeros((no,no),dtype=o_dtype)
                        if options['outer_einsum']=='False':
                            np.matmul(outer,FRAC.reshape(na*nx*noT), out=Bij)
                        else:
                            np.einsum('ij   ,  ik    ,  i -> jk',
                                      xi_ijk, xid_ijk, FRAC.reshape(na*nx*noT),
                                      optimize=True, out=Bij)
                        if W_inv:
                            _MR      = (m + Bij )
                            _MI      = (m + Bij )*1j
                            _M[rms, rms] = _MR.real
                            _M[ims, rms] = _MR.imag
                            _M[rms, ims] = _MI.real
                            _M[ims, ims] = _MI.imag
                            iBij    = inv(_M)
                            _M[:,:] = 0.0
                    
                    FRAC2 = 1j*deltaP[a,x,c]/(xpm[a,x,c] -xpp[a,x,c])
                    if W_inv:
                        # Woodberry inverse uses prec = (A + \sum_v v.T*v)^-1
                        vu[:,:],vv[:,:] = 0.0,0.0
                        vec   = xi[a,x,c,:]
                        vecr,veci = vec.real, vec.imag
                        Fr,Fi = FRAC2.real, FRAC2.imag
                        # T1
                        vu[:no,0] = vecr
                        vv[:no,0] = Fr*vecr - Fi*veci
                        vv[no:,0] = Fr*veci + Fi*vecr
                        # T2
                        vu[:no,1] = veci
                        vv[:no,1] = -(Fr*veci - Fi*vecr)
                        vv[no:,1] =   Fr*vecr - Fi*veci
                        # T3
                        vu[no:,2] = vecr
                        vv[:no,2] =   Fr*veci + Fi*vecr
                        vv[no:,2] = -(Fr*vecr - Fi*veci)
                        # T4
                        vu[no:,3] = veci
                        vv[:no,3] =   Fr*vecr - Fi*veci
                        vv[no:,3] = -(Fr*veci - Fi*vecr)
                        # Woodbury identity
                        prec = iBij - mdot([iBij, vu, 
                                            inv(np.eye(4)+mdot([vv.T, iBij, vu])), 
                                            vv.T, iBij])
                    else:
                        outer2   = xi[a,x,c,:,None]*(xi[a,x,c,None,:])
                        Cij      = FRAC2*outer2
                        _MR      = (m + Bij + Cij)
                        _MI      = (m + Bij - Cij)*1j
                        _M[rms, rms] = _MR.real
                        _M[ims, rms] = _MR.imag
                        _M[rms, ims] = _MI.real
                        _M[ims, ims] = _MI.imag
                        prec     = np.linalg.inv(_M).astype(dtype)
                    if options['extreme_memory_save']=='True':
                        prec2 = prec.astype(np.float16)
                        if not np.isinf(prec2).any():
                            del prec
                            prec = prec2
                        else:
                            print('float16 conversion failed')
                    vals.append(prec.copy())
                    slices1 += [np.arange( 2*it*no,     (2*it+1)*no)]
                    slices2 += [np.arange((2*it+1)*no,  2*(it+1)*no)]
                    it+=1
            if options['prec_to_disk']=='True':
                dic = {'arr'+str(i):vals[i] for i in range(len(vals))}
                np.savez_compressed('Preconditioner_'+str(a),  **dic)
        
        del outer, prec, Bij, FRAC, FRAC2, m, _M
        if options['prec_to_disk']!='True':
            out = sp.block_diag(vals,format='csr')
        del vals
        
        if W_inv:
            del iBij
        else:
            del Cij
        if options['prec_to_disk']=='True':
            first =True
            for a in range(na):
                arc  = np.load('Preconditioner_'+str(a)+'.npz')
                nb   = len(arc.files)
                slc  = np.array_split(np.arange(nb), 5)
                for sl in slc:
                    vals = [arc['arr'+str(i)] for i in sl]
                    if  a == 0 and first:
                        out  = sp.block_diag(vals,format='csr')
                        first= False
                    else:
                        out  = sp.block_diag([out]+vals, format='csr')
                    for _k in range(len(vals)):
                        vals[_k] = None
        
        slices1 = np.hstack(slices1)
        slices2 = np.hstack(slices2)
        idx     = np.hstack((slices1, slices2))
        absdata = np.abs(out.data)
        out.data[absdata<((absdata.max() * 1e-5))]=0.0
        out.eliminate_zeros()
        return out[idx[:,None], idx[None,:]]
    print(pref + 'Constructing Preconditioner')
    print(pref + 'Using dense blocks for the preconditioner ')
    if options['extreme_memory_save']=='True':
        print(pref + ' Attempting to use float16 during construction of preconditioner! ')
    bvec     = B3()
    print(pref + 'Construct preconditioner done.')
    def matvec3(v):
        return Av3(v, outvec, OPSI, alloc_psi, psic#, includefrac=fracdef
                   )
    N        =  2 * npsi
    outvec   =  np.zeros(2*npsi,dtype=np.float64)
    OPSI     =  np.zeros((na,nx,noT, no), dtype=np.complex128)
    alloc_psi=  np.zeros((na,nx,noT, no), dtype=np.complex128)
    psic     =  np.zeros((na,nx,noT, no), dtype=np.complex128)
    if options["use_preconditioner"]=='True':
        preconditioner  = diagmat()
        x        = preconditioner@bvec
    else:
        preconditioner = None
        x = np.random.random(len(bvec),dtype=complex)
    if options['add_random']=='True':
        x   += np.random.random(len(bvec))*float(options['random_weight'])
    if options['start_psi']!='None':
        x    = np.load(options['start_psi'])[IK].reshape(na*nx*noT*no)
        x = np.hstack([x.real, x.imag])
        print(pref + "Read initial Psi given in "+options["start_psi"])
    print(pref + options['Axb_solver'] + ' solver started')
    LO       = LinearOperator((N,N), matvec = matvec3,dtype=np.float64)
    maxit     = int(options['maxiter'])
    fails     = 0
    fracdef   =  0.0
    step      = float(options['dl'])
    t1        = time()
    x,info,its= solve_sparse(LO, bvec, 
                             x0=x, tol=float(options['steptol']), )
    t2        = time()
    if info==0:
        print(pref+'Converged psi in ', its, ' iterations. ('+str(np.round(t2-t1,3))+' secs)')
    else:
        print(pref+'SciPy info: ', info,' Calculation didnt succeed.')
    
    psi       =  x[0:npsi] + 1j * x[npsi:2*npsi]
    PSI[IK]   = psi.reshape(1,na, nx, noT, no)
    for a in range(na):
        for x in range(nx):
            for o in range(noT):
                for aa in range(na):
                    for xx in range(nx):
                        #for oo in range(noT):
                        OMG [IK,a,x,o,aa,xx,:] = -(        ixi[   aa,xx,:].dot(PSI[IK,a,x,o]) * deltaM[aa,xx,:]
                                                   +np.conj(PSI[IK,aa,xx,:]).dot(   xi[a,x,o]) * deltaP[a,x,o]
                                                    )*(1j*hbar)/(xpm[aa, xx,:] - xpp[a,x,o])
    
    # Calculate Derivative
    if options['checkderivative']=='True':
        dPsi = np.zeros(PSI.shape,dtype=complex)
        for a in range(na):
            for x in range(nx):
                for c in range(noT):
                    dPsi[0,a,x,c]  = (h0 - I*xpp[a,x,c])@PSI[IK,a,x,c] + hbar * glp[a,x,c]*xi[a,x,c]+ hbar*deltaP[a,x,c]*(dm0@xi[a,x,c])
                    dPsi[0,a,x,c] += (xi.reshape(na*nx*noT,no).T@(OMG[IK,a,x,c].reshape(na*nx*noT)))/hbar
        print('sum over |Derivative| of psi_axc')
        sum_abs_psi  = np.abs(dPsi).sum()
        sum_psi_vec += [sum_abs_psi]
        print(sum_abs_psi)
        PI = np.zeros((na,no,no),dtype=complex)
        for ia in range(na):
            PI[ia] = Q_nb(PSI[[IK], ia], IXI[[IK], ia])
        J = np.trace(PI, axis1=1,axis2=2)/hbar
        Q = (1/hbar)*(PI.sum(axis=0))
        print(pref +'----------------')
        print('         Current running with this DM at ik='+str(IK)+':  ', J)
        dSig = (-1j/hbar)*(h0@dm0 - dm0@h0) + Q
        dsig_abs_max = np.abs(dSig).max()
        sig_absmax_vec += [dsig_abs_max]
        print('         max(|DM derivative|) ', dsig_abs_max)
        print('')
        if options['L_info']=='True':
            print('         Current term Q projection onto |psi_i><psi_i| of the Hamiltonian: ')
            print(np.diag(np.abs(L0.proj_null(Q, 0))))
            print('         DM projection onto |psi^i><psi_i| of the Hamiltonian: ')
            print(np.diag(np.abs(L0.proj_null(dm0, 0))))
        
        print(pref +'----------------------')
        
files = os.listdir()
savedir=options['file']+'_save'
if savedir not in files:
    os.mkdir(savedir)
np.save(savedir+'/last_psi.npy',PSI)
np.save(savedir+'/last_omg.npy',OMG)
if (np.array(sum_psi_vec) < 1e-5).all():
    success_psi = True
else:
    success_psi = False
if (np.array(sig_absmax_vec) < 1e-2).all():
    success_sig = True
else:
    success_sig = False
with open("psinought_dpsi_MESSAGE.txt","w") as f:
    if success_psi:
        f.write("Success")
    else:
        f.write("Failure")    
with open("psinought_dsig_MESSAGE.txt","w") as f:
    if success_sig:
        f.write("Success")
    else:
        f.write("Failure")    



