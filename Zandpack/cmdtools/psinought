                           # tol=tol, deprecated by scipy-1.14
                           # atol=tol,
                           rtol=tol,
                           x0=x0, 
                           callback=callback, 
                           maxiter=int(options['maxiter']), 
                           M = preconditioner
                           )
    return x,status,num_iters
def SM(iA, u, v, out):
    idx = np.where(np.abs(u)>1e-10)[0]
    iAu = iA[:,idx]@u[idx]
    np.multiply.outer(iAu[:,0], ((v.T/(1.+v.T@iAu))@iA)[:,0], out = out)
    iA -= out

PSI = np.zeros((nk,na,nx, noT,no),dtype=complex)
OMG = np.zeros((nk,na,nx, noT,na,nx, noT),dtype=complex)

print(pref + 'Converging steady-state with DM from     '+options['file']+'/Arrays/   folder.')
print(pref + 'Particle number: ', np.trace(DM0,axis1=1,axis2=2))
