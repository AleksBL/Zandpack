C = -1j / hbar
def heis(t, y):
    dm   = y.reshape(nk, no, no)
    if NI:
        Hdm  = dm2h(t, dm0)
    else:
        Hdm  = dm2h(t, dm)
    res  = Hdm @ dm
    res -= res.conj().transpose(0,2,1)
    assert np.abs(dm  -  dm.conj().transpose(0,2,1)).max()<1e-7, "ERROR : " +str(np.abs(dm- dm.conj().transpose(0,2,1)).max()) + " at t="+str(t)
    assert np.abs(Hdm - Hdm.conj().transpose(0,2,1)).max()<1e-7, "ERROR : " +str(np.abs(Hdm- Hdm.conj().transpose(0,2,1)).max()) + " at t="+str(t)
    res *= C
    return res.ravel()    

