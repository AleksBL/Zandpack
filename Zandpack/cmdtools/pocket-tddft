@njit
def calcJDOS(E, e, fe, eta):
    out = 0.0 + 0.0j
    n   = len(e)
    ieta= 1/eta
    for i in range(n):
        for j in range(n):
            fd  = fe[i] - fe[j]
            ed  = e[j]  - e[i]
            out+= fd * np.exp(-(((E - ed)*(ieta))**2))
    return out

@njit
def calc_whole_jdos(hw_v, e, fe, eta):
    nk = e.shape[0]
    res = np.zeros((nk, hw_v.shape[0]),dtype=np.complex128)
    for ik in range(nk):
        for i in range(len(hw_v)):
            res[ik, i] = calcJDOS(hw_v[i], e[ik], fe[ik], eta)
    return res

