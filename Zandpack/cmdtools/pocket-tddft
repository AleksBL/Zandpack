def dm2DM(dm):
    ic = 0
    for i in idx:
        jc = 0
        for j in idx:
            DM_full[:,i,j] = dm[:, ic, jc]
            jc += 1
        ic += 1
@njit
def dm2DM_fast(dm, DM):
    ic = 0
    for i in idx:
        jc = 0
        for j in idx:
            DM[:,i,j] = dm[:, ic, jc]
            jc += 1
        ic += 1

def f(E):
    return 1/(1 + np.exp((E - mu)/kT))

def undiag(f,v):
    F = np.zeros(v.shape,dtype=complex)
    for i in range(f.shape[-1]):
        F[:, i,i] = f[:,i]
    return v @ F @ np.conj(v.transpose(0,2,1))

def h2dm(h):
    e,v = np.linalg.eigh(h)
    fe  = f(e)
    dm  = undiag(fe, v)
    return dm
def proj2inds(M):
    if M.ndim==2:
        return M[idx[:, None], idx[None,:]]
    elif M.ndim == 3:
        return M[:, idx[:, None], idx[None,:]]
    else:
        assert 1 == 0, "Dim error in proj2inds"
def dm2h(t, dm):
    # dm2DM(dm)
    dm2DM_fast(dm, DM_full)
    return h0 + proj2inds(dH(t, DM_full))
nk    = 1
