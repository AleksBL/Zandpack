import sys
import os
import numpy as np
from Zandpack.FittedSelfEnergy import from_saved_file
from Zandpack.PadeDecomp import FD_expanded, Pade_poles_and_coeffs, Hu_poles, FD
from Block_matrices.Block_matrices import abssorted_eig_4inds as Sorted_eig
from Zandpack.Linalg_factorisation import SVD, TAKAGI, QR
from Zandpack.Loader import flexload

pref = 'modify_occupations  '
args = sys.argv[1:]
print(pref+'Program Start')
print('')
print(pref+'sys.argv:', sys.argv)
print('')

#Default values
options = {'file'   :'TDT_file',
           'outfile':'NewTDT_file',
           'mu_i'   :'0.0,0.0',
           'kT_i'   :'0.025,0.025',
           'pole_mode':'JieHu2011',
           'N_F':'20',
           'eigtol':'1e-8',
           'use_exact_fermi':'False',
           'print_eigf':'False',
           'print_eigl':'False',
           'factorisation':'eigen',
           'new_lead':'False',
           'scale_gamma': 'None'
           }

os.chdir(os.getcwd())

if '--help' in args:
    print('Keywords and default values. Assign with "keyword=value" argument after modify_occupations command (no spaces!)')
    for keys,values in options.items():
        print(keys, ':', values)
    exit()

for a in args:
    split = a.replace(' ', '').split('=')
    options.update({split[0]:split[1]})

file    = options['file']
outfile = options['outfile']
if options['new_lead'] == 'False':
    n_new_lead = 0
else:
    # NewLead is a dictionary containing the information of the lead
    # 
    n_new_lead = 1
    exec('from '+options['new_lead'].replace('.py','') + ' import NewLead')
    print('Imported new lead from '+options['new_lead'])

if options['factorisation']=='eigen':
    _n = 2
else:
    _n = 1


sedir=file+'/Arrays'
SEs  = from_saved_file(sedir)

#Gl_eig0   =  flexload(sedir + '/_Gl_Eigenvalues.npy')
num_l     =  flexload(sedir + '/num_lorentzians.npy')
num_leads =  flexload(sedir + '/num_leads.npy'      ) + n_new_lead
mu_i      =  np.fromstring(options['mu_i'], sep = ',')
kT_i      =  np.fromstring(options['kT_i'], sep = ',')
N_F       =  int(options['N_F'])
Hs        =  flexload(sedir+'/H_Ortho.npy').shape
nk,no     =  Hs[0],Hs[-1]

if options['pole_mode'] == 'JieHu2011':
    zi,ci = Hu_poles(N_F)
elif options['pole_mode'] == 'Croy2009':
    zi,ci = Pade_poles_and_coeffs(N_F)
print('#  Leads: ', num_leads)
F_poles = np.zeros((num_leads, N_F), dtype = np.complex128)
print('Fermi function pole shape: ', F_poles.shape)
for a in range(num_leads):
    for i in range(N_F):
        F_poles[a,i]     = mu_i[a] + zi[i]*kT_i[a] # The poles of the expanded fermifunction on the upper
if len(mu_i)!=num_leads:
    print(pref+'error in input mu_i')
    exit()
eps_l    = np.zeros((nk,num_leads, num_l))
gam_l    = np.zeros((nk,num_leads, num_l))
for a in range(num_leads):
    if options['new_lead']=='False' or a<(num_leads-1):
        eps_l[:,a,:] = flexload(sedir+'/Centres_Lorentzian_'+str(a)+'.npy')
        gam_l[:,a,:] = flexload(sedir+'/Broadening_Lorentzian_'+str(a)+'.npy')
    elif options['new_lead']!='False':
        print('Using new lead information from '+options['new_lead']+'!')
        eps_l[:,a,:] = NewLead['Centres_Lorentzian']
        gam_l[:,a,:] = NewLead['Broadening_Lorentzian']
        
        

Xpp  = np.zeros((nk, num_leads, num_l+_n*N_F, no), dtype=np.complex128)
Xpm  = Xpp.copy()
GGM  = Xpp.copy()
GGP  = Xpp.copy()
GLP  = Xpp.copy()
GLM  = Xpp.copy()
xi   = np.zeros((nk, num_leads, num_l+_n*N_F, no, no), dtype=np.complex128)
Ixi  = xi.copy()
_Gleig = np.zeros((nk, num_leads, num_l, no), dtype=np.complex128)
_Gfeig = np.zeros((nk, num_leads, N_F, no), dtype=np.complex128)
if options['scale_gamma']!='None':
    scale_gamma = np.fromstring(options['scale_gamma'], sep=',')
else:
    scale_gamma = np.ones(num_leads)
print('scale_gamma = ', scale_gamma)
for a in range(num_leads):
    if options['new_lead']=='False' or a<(num_leads-1):
        SEsa = SEs[a]
    elif options['new_lead']!='False':
        print('Using new lead information from '+options['new_lead']+'!')
        # In your editor this might show up as a warning, but its because its loaded
        # with "exec('...')"
        SEsa = NewLead['SEsa']
    mu   = mu_i[a]
    kT   = kT_i[a]
    ea   = eps_l[:,a,:]
    ga   = gam_l[:,a,:]
    beta = 1/kT
    Wi   = SEsa.Coeffs
    print('Weights shape and PSD checks:')
    assert Wi.shape[0] == nk
    assert Wi.shape[2] == no
    assert Wi.shape[3] == no
    assert np.allclose(Wi, Wi.conj().transpose(0,1,3,2))
    print('Checks okay')
    
    Zl   = ea + 1j*ga
    correct_F = F_poles[a][None,:][[0]*nk]
    xpp  = np.hstack((Zl,        correct_F,       correct_F))
    xpm  = np.hstack((Zl.conj(), correct_F.conj(),correct_F.conj()))
    
    
    
    #if options['factorisation']!='eigen':
    #    xpp  = np.hstack((Zl,        F_poles[None,a]))
    #    xpm  = np.hstack((Zl.conj(), F_poles[None,a].conj()))
    #else:
    
    Ga_in_poles_p  = SEsa.evaluate_gamma(F_poles[a]       )
    Ga_in_poles_m  = SEsa.evaluate_gamma(F_poles[a].conj())
    
    B  =  Ga_in_poles_p + Ga_in_poles_p.conj().transpose(0,1,3,2)
    C  =  Ga_in_poles_p - Ga_in_poles_p.conj().transpose(0,1,3,2)
    B *=  (0.5 +0j)
    C *=  (0.5 +0j)
    
    BB  =  Ga_in_poles_m + Ga_in_poles_m.conj().transpose(0,1,3,2)
    CC  =  Ga_in_poles_m - Ga_in_poles_m.conj().transpose(0,1,3,2)
    BB *=  (0.5 +0j)
    CC *=  (0.5 +0j)
    
    
    Ga_c = (Ga_in_poles_p.conj().transpose(0,1,3,2))
    Gm_c = (Ga_in_poles_m.conj().transpose(0,1,3,2))
    
    assert np.allclose(Wi, Wi.conj().transpose(0,1,3,2))
