                                            ), axis = 1)
        
        
        print('Condition number of vecf1: ',np.linalg.cond(vecf1) )
        Ixi[:,a,:,:,:]    = np.concatenate((vecl .transpose(0,1,3,2).conj(),
                                           ivecf1.transpose(0,1,2,3)
                                            ),axis = 1 )
        
    if options['factorisation']=='eigen':
        eigl, vecl        = Sorted_eig(Wi,            hermitian = True)
        eigf1, vecf1      = Sorted_eig(Ga_in_poles_p, hermitian = False)
        eigf2, vecf2      = Sorted_eig(Ga_in_poles_m, hermitian = False)
        
        eB, vB            = Sorted_eig(B)
        eC, vC            = Sorted_eig(C)
        
        eBB, vBB          = Sorted_eig(BB)
        eCC, vCC          = Sorted_eig(CC)
        
        # scale gamma eigenvalues by scale_gamma
        print('Scaling eigenvalues of Gamma_'+str(a)+' by '+ str(scale_gamma[a]))
        eigl  *= scale_gamma[a]
        eigf1 *= scale_gamma[a]
        eigf2 *= scale_gamma[a]
        eB    *= scale_gamma[a]
        eC    *= scale_gamma[a]
        eBB   *= scale_gamma[a]
        eCC   *= scale_gamma[a]
        
        _Gleig[:,a,:,:]   = eigl
        _Gfeig[:,a,:,:]   = eigf1
        
        xi[:,a,:,:,:]     = np.concatenate((vecl.transpose(0,1,3,2), 
                                              vB.transpose(0,1,3,2),
                                              vC.transpose(0,1,3,2)
                                              ), axis = 1)
        
        Ixi[:,a,:,:,:]    = np.concatenate((vecl.transpose(0,1,3,2).conj(),
                                              vB.transpose(0,1,3,2).conj(),
                                              vC.transpose(0,1,3,2).conj()
                                              ),axis = 1 )
    
    print(eigf1.max())
    print(eigl.max())
    Xpp[:,a,:,:] = xpp[:,:,None]
    Xpm[:,a,:,:] = xpm[:,:,None]
    
    for ik in range(nk):
        max_error = 0.0
        for l in range(num_l):
            gkl  =  Zl [ik, l].imag
            if options['use_exact_fermi']=='False':
                fz   = FD_expanded(np.array([Zl[ik,l]])       , zi, beta, mu=mu, coeffs=ci)[0]
                fzc  = FD_expanded(np.array([Zl[ik,l].conj()]), zi, beta, mu=mu, coeffs=ci)[0]
            elif options['use_exact_fermi']=='True':
                fz   = FD(Zl[ik,l]       ,  beta, mu=mu)
                fzc  = FD(Zl[ik,l].conj(),  beta, mu=mu)
            
            rfz  = FD(Zl[ik,l],        beta, mu = mu)
            rfzc = FD(Zl[ik,l].conj(), beta, mu = mu)
            
            for o in range(no):
                eklo = eigl[ik, l, o]
                v1    =  0.5j *    fz    * eklo * gkl
                v2    =  0.5j *    fzc   * eklo * gkl
                v3    = -0.5j * (1-fz )  * eklo * gkl
                v4    = -0.5j * (1-fzc)  * eklo * gkl
                
                rv1   =  0.5j *    rfz   * eklo * gkl
                rv2   =  0.5j *    rfzc  * eklo * gkl
                rv3   = -0.5j * (1-rfz ) * eklo * gkl
                rv4   = -0.5j * (1-rfzc) * eklo * gkl
                
                GLP[ik, a, l, o] =  v1
                GLM[ik, a, l, o] =  v2
                GGP[ik, a, l, o] =  v3
                GGM[ik, a, l, o] =  v4
                
                mxer = max((abs(v1-rv1), abs(v2-rv2), abs(v3-rv3),abs(v4-rv4)))
                if mxer > max_error:
                    max_error = 0.0 + mxer
        
        print('Max error on (ik,ia) = ', (ik,a), 'is ', max_error)
        
        for p in range(N_F):
            for o in range(no):
                if options['factorisation']!='eigen':
                    eklo1 = eigf1[ik, p, o]
                    eklo2 = eigf2[ik, p, o]
                    
                    
                    GLP[ik, a, p+num_l, o] = +kT * eklo1 * ci[p]
                    GLM[ik, a, p+num_l, o] = -kT * eklo2 * ci[p]
                    GGP[ik, a, p+num_l, o] = +kT * eklo1 * ci[p]
                    GGM[ik, a, p+num_l, o] = -kT * eklo2 * ci[p]
                else:
                    eklo1b = eB [ik, p, o]
                    eklo2b = eBB[ik, p, o]
                    eklo1c = eC [ik, p, o]
                    eklo2c = eCC[ik, p, o]
                    
                    GLP[ik, a, p+num_l, o] = +kT * eklo1b * ci[p]
                    GLM[ik, a, p+num_l, o] = -kT * eklo2b * ci[p]
                    GGP[ik, a, p+num_l, o] = +kT * eklo1b * ci[p]
                    GGM[ik, a, p+num_l, o] = -kT * eklo2b * ci[p]
                    
                    GLP[ik, a, p+num_l+N_F, o] = +kT * eklo1c * ci[p]
                    GLM[ik, a, p+num_l+N_F, o] = -kT * eklo2c * ci[p]
                    GGP[ik, a, p+num_l+N_F, o] = +kT * eklo1c * ci[p]
                    GGM[ik, a, p+num_l+N_F, o] = -kT * eklo2c * ci[p]
        

print('Maximum of eigenvalues of Lorentzian Gammas: ' + str(np.round(_Gleig.max(),6)))
print('Minimum of eigenvalues of Lorentzian Gammas: ' + str(np.round(_Gleig.min(),6)))
print('Maximum of eigenvalues of Fermi-pole Gammas: ' + str(np.round(_Gfeig.max(),6)))
print('Minimum of eigenvalues of Fermi-pole Gammas: ' + str(np.round(_Gfeig.min(),6)))

