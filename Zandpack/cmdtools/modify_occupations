    #assert not np.allclose(Ga_in_poles_m@ Gm_c, (Gm_c@Ga_in_poles_m))
    assert np.allclose(B@(B.transpose(0,1,3,2).conj()), B.transpose(0,1,3,2).conj()@B)
    assert np.allclose(C@(C.transpose(0,1,3,2).conj()), C.transpose(0,1,3,2).conj()@C)
    
    if options['factorisation']=='wrong_eigen':
        print('Using eigen-decomposition of Gamma_'+str(a)+'(z_F)')
        eigl, vecl        = Sorted_eig(Wi,            hermitian = True)
        eigf1, vecf1      = Sorted_eig(Ga_in_poles_p, hermitian = False)
        eigf2, vecf2      = Sorted_eig(Ga_in_poles_m, hermitian = False)
        _Gleig[:,a,:,:]   = eigl
        _Gfeig[:,a,:,:]   = eigf1
        ivecf1            = np.linalg.inv(vecf1)
        
        
        if not np.allclose(Ga_in_poles_p@ Ga_c, (Ga_c@Ga_in_poles_p)):
            print('------->Gamma in fermipole not normal')
        
        xi[:,a,:,:,:]     = np.concatenate((vecl.transpose(0,1,3,2), 
