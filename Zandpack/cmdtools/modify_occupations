delete = ['diff_GGM_GLM','diff_GGP_GLP','GG_M', 'GL_M', 'GL_P','GG_P', 
          '_Gl_Eigenvalues', '_Gp_Eigenvalues', 
          'xi','Ixi', 'Xpp', 'Xpm',
