# Function for density matrix EOM
def SIGMA(stepsize=stepsize, T0=t0, T1=t1):
    filename =name+".MASTER"
    with open(filename,'w') as file:
        file.write('\nfile for Master node\n\n')
    # Stepsize updater
    # eps: error-tolerance
    # TE : calculated error
    def hnew(h, TE): 
        return 0.9 * h * (eps / TE) ** 0.2
    H0      = D['H_Ortho']
    Ht      = CZ(H0.shape)
    # Possibly load in saved files
    if usesave == False:
        sig0    = D['DM_Ortho'].copy()
        t0      = T0
        h       = stepsize
    else:
        sig0    = np.load(name+'_save/'+'last_sig.npy')
        try:
            t0      = float(np.load(name+'_save/'+'last_time.npy'))
            h       = float(np.load(name+'_save/'+'last_stepsize.npy'))
        except:
            t0 = 0.+T0
            h  = 0.+stepsize
            
    # Create save directory
    try:
        os.mkdir(name+'_save')
    except:
        pass
    files = os.listdir(name+'_save')
    for f in files:
        if f[0:2]=='DM':
            os.remove(name+'_save/'+f)
        
    # Arrays to place values of various intermediate samplings in the Runge-Kutta-method
    tmp_sig     = D['DM_Ortho'].copy()
    tmp_PI      = CZ((NK, NA, NO, NO))
    SIGS        = CZ((RK_N+1,)+tmp_sig.shape)
    Delta_a     = np.zeros(NA)
    
    global_psi  = CZ((NK, NA, NOT, NL, NF+1))
    
    #Initial Values for sigma
    SIGS[-1] = sig0
    del sig0
    
    # Arrays to assemble PI and PSI in.
    # the MPI4py needs them to be preallocated.
    PI_buff = []
    for v in Worker_idx:
        #             local nk     # local na  orb orb
        PI_buff += [ CZ((len(v[0]), 1, NO, NO)) ]
    PSI_buff = []
    for v in Worker_idx:
        #             local nk     # local na local no               orb
        PSI_buff += [ CZ((len(v[0]), 1,       noT_lead[v[1][0]],  len(v[3]),len(v[4]), NO)) ]
    
    
    TIME_START = time(); step_count = 0
    currents   = [[] for i in range(NL)]
    DM         = [SIGS[-1].copy()]
    times      = [t0]
    PI_holder    =  []
    list_request =  [None for i in range(len(src))]
    worker_errors = [np.zeros(2) for i in range(len(src))]
    dt = np.zeros(len(A),dtype=float)
    
    while t0 < t1:
        Step_Fourth = 0 # 0 or 1. 0 repeats same step with lesser stepsize, 1 propagates
        _Timer.reset()
        _Timer.time(["Main Loop"])
        while Step_Fourth == 0:
            dt[:] = A[:]
            dt   *= h
            for i in range(RK_N):
                _Timer.time(["Initial Matrix Multiplication"])
                _idx_i = idxholder[i, 0:i+1] #Indexing for computing intermediate result, see mpi_funcs.py
                if i==0: tmp_sig[:,:,:] = SIGS[-1]
                else:    MM(SIGS[_idx_i].transpose(1, 2, 3, 0) , B[i, _idx_i], tmp_sig)
                _Timer.time(["Initial Matrix Multiplication", 
                             "System creation at ts"])
                # system parameters at the time ts
                ts = t0 + dt[i]; 
                Ht = H0 + dH(ts, tmp_sig)
                for _not_i in range(NA): Delta_a[_not_i] = bias(ts, _not_i)
                _Timer.time(["System creation at ts", 
                             "Broadcast System at ts"])
                # Broadcast system parameters to worker nodes
                h   = comm.bcast(h , root=0)
                ts  = comm.bcast(ts, root=0)
                comm.Bcast(Ht      , root=0)
                comm.Bcast(tmp_sig , root=0)
                comm.Bcast(Delta_a , root=0)
                _Timer.time(["Broadcast System at ts", 
                             "Commutator for sigma"])
                
                # While the worker nodes compute, the master node computes 
                # the RHS of the sigma EOM.
                #                                           hbar multiplied with here, gets divided with later
                D_tmp_sig = -1j*(Ht@tmp_sig - tmp_sig@Ht) - hbar*dissipator(ts, tmp_sig)
                _Timer.time(["Commutator for sigma", 
                             "Assemble global Psi"])
                
                # Collect PSI parts, assemble and resend to nodes
                for kk in range(len(src)):
                    widx = Worker_idx [kk]
                    wtag = Worker_tags[kk]
                    comm.Recv( PSI_buff[kk],
                               source = src[kk], tag = wtag)
                    #print(np.sum(PSI_buff[kk]))
                    # nk, lead, pole, eig slices and assigning
                    global_psi[widx[0][:,    None, None, None, None],
                               widx[1][None,    :, None, None, None],
                               widx[2][None, None, :   , None, None], 
                               widx[3][None, None, None,:    , None],
                               widx[4][None, None, None, None, :   ], :] = PSI_buff[kk]
                
                _Timer.time(["Assemble global Psi", 
                             "Broadcast global Psi"])
                
                comm.Bcast(global_psi, root = 0)
                _Timer.time(["Broadcast global Psi", 
                             "Recieve PI"])
                
                # Reset PI and Collect work 
                tmp_PI[:,:,:,:] = 0.0 
                # Summing over subsets of Poles here, if these have been split
                for kk in range(len(src)):
                    widx = Worker_idx [kk]
                    wtag = Worker_tags[kk]
                    list_request[kk] = comm.Irecv(PI_buff[kk],
                                                  source=src[kk], tag=wtag)
                
                done_workers = []
                lensrc       = len(src)
                while len(done_workers)<lensrc:
                    for kk, req in enumerate(list_request):
                        if req.test()[0] and kk not in done_workers:
                            widx = Worker_idx [kk]
                            wtag = Worker_tags[kk]
                            # PI here is really Q = PI + PI^T
                            tmp_PI[widx[0][:, None],
                                   widx[1][None, :], :,:] += PI_buff[kk]
                            done_workers += [kk]
                
                list_request[0].Waitall(list_request)
                _Timer.time(["Recieve PI",
                             "Calculate Currents"])
                
                if i == 0:  # Calculate currents from Q
                    for elec_count in range(NL):
                        currents[elec_count] += [np.trace(tmp_PI[:,elec_count], 
                                                          axis1 = 1, axis2 = 2).real/hbar]
                    if save_PI:
                        # Save COPY of PI. tmp_PI object is continuously getting modified.
                        PI_holder += [tmp_PI.copy()]
                
                _Timer.time(["Calculate Currents",
                             "Sigma EOM"])
                
                # Sigma EOM, commutator done already:
                # Note we are using Q_nb instead of PI in the worker nodes. 
                # tmp_PI name used for not having to rename arrays. the current
                # calculation as just the trace have been updated also.
                Q_sum      = tmp_PI.sum(axis = 1)
                D_tmp_sig += Q_sum
                
                D_tmp_sig *= (h/hbar)
                SIGS[i, :, :, :] = D_tmp_sig[:, :, :]
                _Timer.time(["Sigma EOM"])
            
            _Timer.time(["Collect Error"])
            TE2_1 = TERR2_sig(SIGS[0:RK_N], CT)
            for kk in range(len(src)):
                comm.Recv(worker_errors[kk], source=src[kk],tag=Worker_tags[kk])
            _Timer.time(["Collect Error",
                         "Calculate Error"])
            TE = (TE2_1 + sum(sum(worker_errors)))**0.5
            Step_Fourth = 1 if TE < eps else 0
            if Step_Fourth == 0:
                for elec_count in range(NL):
                    currents[elec_count] = currents[elec_count][:-1]
                if save_PI:
                    PI_holder = PI_holder[:-1]
                    
            _Timer.time(["Calculate Error",
                         "Broadcast Succes or Failure"])
            Step_Fourth = comm.bcast(Step_Fourth, root = 0)
            _Timer.time(["Broadcast Succes or Failure",
                         "Update Stepsize"])
            old_h       = 0.0 + h
            h           = hnew(h,  TE)
            _Timer.time(["Update Stepsize"])
        _Timer.time(["Main Loop"])
        _Timer.time(["Save State"])
        
        pass_checkpoint_and_not_saved = (t0>checkpoints) * (checkpoint_bookkeeper == 0)
        if save_checkpoints and pass_checkpoint_and_not_saved.any():
            np.save(name+'_save/'+'last_sig'     , SIGS[-1])
            np.save(name+'_save/'+'last_time'    ,       t0)
            np.save(name+'_save/'+'last_stepsize',    old_h)
            idx = np.where(pass_checkpoint_and_not_saved)[0][0]
            checkpoint_bookkeeper[idx] = 1
        
        _Timer.time(["Save State"])
        _Timer.time(["Update Sigma"])
        step_fourth_sig(SIGS, CH)
        _Timer.time(["Update Sigma"])
        
        _Timer.time(["Intermediate Save"])
        t0         += h
        DM         += [SIGS[-1].copy()]
        times      += [t0 + 0.0]
        step_count += 1
        _Timer.time(["Intermediate Save"])#, skip_next = [True])
        _Timer.time(["Full Save"])
        if np.mod(step_count, saveevery)==0 and step_count>=saveevery:
            np.save(name+'_save/DM'+str(step_count), np.array(DM[::n_dm_compress]).astype(np.complex64))
            dm_times = np.array(times[-len(DM):])
            if len(dm_times)>len(DM): dm_times = dm_times[1:]
            np.save(name+'_save/DMt'+str(step_count), dm_times[::n_dm_compress])
            if save_PI:
                np.save(name+'_save/PIa'+str(step_count), np.array(PI_holder[::n_dm_compress]).astype(np.complex64))
            
            np.save(name+'_save/times'+str(step_count), times[-len(DM):])
            for k, c in enumerate(currents):
                np.save(name+'_save/'+'current_'+str(k) + '_'+str(step_count), c[-len(DM):])
            DM        = []
            PI_holder = []
            
            print('t = ' + str(t0) + ' | number of steps = ' + str(step_count) + ' | local error:' +str(format(TE, '.3e')))
            for k, c in enumerate(currents):
                _cur = np.array(c[-1])
                print('   Current in lead ' + str(k) + ': ' + str(np.round(_cur,6))[1:-1] + '| Total: ' + str(np.round(sum(c[-1]),6)))
        _Timer.time(["Full Save"], skip_next = [True])
        mystring = _Timer.generate_timings()
        if print_timings:
            with open(filename,'a') as file:
                file.write(mystring)
    TIME_STOP = time()
    print('RUNTIME: ', TIME_STOP - TIME_START)
    comm.bcast(None, root = 0)
    return

