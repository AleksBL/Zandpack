                MM(xi, tmp_sig.transpose((0, 2, 1))[:,nax,nax,nax], alloc_psi_1)              #  diff * sig * xi    term
                _multiply(d_ggp_glp, alloc_psi_1, out = alloc_psi_1)
                PSIS[i] += alloc_psi_1
                
                add_omg2_2_omg1(tmp_omg1, tmp_omg2)
                
