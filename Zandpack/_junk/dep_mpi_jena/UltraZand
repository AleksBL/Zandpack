                # Only vector entries>small_tol is included in the dot product
                # note the indicing of the summed variables in the line below
                
                # OMG1 is the vertical "column" of OMG in the xx' indices
                OMGS1[i] = (tmp_psi.reshape(nk, na*neig*nl*nf, NO) 
                            @ 
                           ((d_ggm_glm_all[:,:,:,:,0][... , nax]*Ixi_all).reshape(nk, NA*NOT*NL, NO)).transpose(0,2,1)
                           ).reshape(nk, na, neig, nl, nf, NA, NOT, NL, 1)
                
                OMGS1[i] += ((d_ggp_glp[:,:,:,:,0][... , nax] * xi).reshape(nk, na*neig*nl, NO)
                              @
                             (psi_tilde[:,:,:,:,0]).reshape(nk, NA*NOT*NL, NO).transpose(0,2,1)
                             ).reshape(nk, na, neig, nl, nf, NA, NOT, NL, 1)
                
                # OMG1 is the horisontal "row" of OMG in the xx' indices
                OMGS2[i] = (tmp_psi[..., 0, :].reshape(nk, na*neig*nl,NO)
                              @
                             (d_ggm_glm_all[...,1:, nax]*Ixi_all[...,nax,:]).reshape(nk, NA*NOT*NL*(NF+1), NO).transpose(0,2,1)
                        ).reshape(nk, na, neig,nl,1,NA,NOT,NL,NF)
                
                OMGS2[i] = ((d_ggp_glp[...,0][...,nax] * xi).reshape(nk, na*neig*nl,NO)
                              @
                             (psi_tilde[:,:,:,:,1:,:].reshape(nk, NA*NOT*NL*NF,NO).transpose(0,2,1) )
                        ).reshape(nk, na, neig,nl,1,NA,NOT,NL,NF)
                
